{
  "$schema": "https://raw.githubusercontent.com/gruncellka/porto-data/refs/heads/main/porto_data/schemas/markets.schema.json",
  "file_type": "markets",
  "description": "Country-level currency, VAT, international quote currencies, and postal working-day calendar. providers.json country resolves fiscal defaults via markets[COUNTRY].",
  "unit": {
    "country_code": "ISO 3166-1 alpha-2",
    "currency": "ISO 4217"
  },
  "markets": {
    "DE": {
      "currency": "EUR",
      "working_days": {
        "weekdays": "mon_sat",
        "exclude_public_holidays": true
      },
      "vat": {
        "exempt": true
      }
    },
    "FR": {
      "currency": "EUR",
      "working_days": {
        "weekdays": "mon_fri",
        "exclude_public_holidays": true
      },
      "vat": {
        "domestic": {
          "inclusive": true
        },
        "international": {
          "inclusive": true
        }
      }
    },
    "CH": {
      "currency": "CHF",
      "working_days": {
        "weekdays": "mon_sat",
        "exclude_public_holidays": true
      },
      "vat": {
        "domestic": {
          "inclusive": true
        },
        "international": {
          "inclusive": true
        }
      }
    },
    "UA": {
      "currency": "UAH",
      "working_days": {
        "weekdays": "mon_fri",
        "exclude_public_holidays": true
      },
      "international_currency": [
        "USD"
      ],
      "vat": {
        "rate": 0.2,
        "domestic": {
          "inclusive": true
        },
        "international": {
          "inclusive": false
        }
      },
      "settlement": {
        "currency": "UAH",
        "fx": "NBU",
        "fx_date": "service"
      }
    }
  }
}
