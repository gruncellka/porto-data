{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/gruncellka/porto-data/refs/heads/main/porto_data/schemas/service_prices.schema.json",
  "title": "Service surcharge prices",
  "description": "Add-on service amounts keyed by service_id (native id from services.json). Convention: price[].effective_from uses the catalog baseline date (currently 2026-01-01) as bundle snapshot start, not carrier historical introduction dates.",
  "type": "object",
  "required": [
    "file_type",
    "provider",
    "unit",
    "service_prices"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "file_type": {
      "type": "string",
      "const": "service_prices"
    },
    "provider": {
      "type": "string",
      "pattern": "^[a-z_]+$",
      "description": "Provider identifier"
    },
    "unit": {
      "type": "object",
      "required": [
        "price",
        "currency"
      ],
      "properties": {
        "price": {
          "type": "string",
          "const": "cents"
        },
        "currency": {
          "type": "string",
          "enum": [
            "EUR",
            "CHF",
            "UAH",
            "USD"
          ]
        }
      },
      "additionalProperties": false
    },
    "service_prices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "service_id",
          "price"
        ],
        "properties": {
          "service_id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$",
            "description": "Must match services.json id"
          },
          "currency": {
            "type": "string",
            "enum": [
              "EUR",
              "CHF",
              "UAH",
              "USD"
            ],
            "description": "Optional override; when omitted, defaults to unit.currency"
          },
          "price": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "amount",
                "effective_from"
              ],
              "properties": {
                "amount": {
                  "type": "integer",
                  "minimum": 0
                },
                "effective_from": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "format": "date",
                  "description": "Row valid from this date. Provider bundles use the catalog baseline (e.g. 2026-01-01) unless superseding rows exist."
                },
                "effective_to": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "format": "date",
                  "description": "Null while current; set when a newer price row replaces this amount."
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
