{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/gruncellka/porto-data/refs/heads/main/porto_data/schemas/graph.schema.json",
  "title": "Graph schema",
  "description": "Provider graph: data file dependencies, relationships, and product edges (zones \u00d7 weight tiers)",
  "type": "object",
  "required": [
    "file_type",
    "provider",
    "unit",
    "dependencies",
    "edges",
    "services"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "description": "JSON Schema URI reference"
    },
    "file_type": {
      "type": "string",
      "const": "graph",
      "description": "File type identifier"
    },
    "provider": {
      "type": "string",
      "pattern": "^[a-z_]+$",
      "description": "Provider identifier (e.g. deutschepost, ukrposhta, laposte, swisspost)"
    },
    "unit": {
      "type": "object",
      "required": [
        "weight",
        "dimension",
        "price",
        "currency"
      ],
      "properties": {
        "weight": {
          "type": "string",
          "const": "g"
        },
        "dimension": {
          "type": "string",
          "const": "mm"
        },
        "price": {
          "type": "string",
          "const": "cents"
        },
        "currency": {
          "type": "string",
          "enum": [
            "EUR",
            "CHF",
            "UAH",
            "USD"
          ],
          "description": "ISO 4217 currency code; must match policy/markets.json markets[providers.json country].currency"
        }
      },
      "additionalProperties": false
    },
    "dependencies": {
      "type": "object",
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "object",
          "required": [
            "file",
            "depends_on",
            "description"
          ],
          "properties": {
            "file": {
              "type": "string",
              "pattern": "^(policy/[a-z0-9_./-]+\\.json|formats/[a-z0-9_./-]+\\.json|[a-z0-9_./-]+\\.json)$",
              "description": "Data path: provider-relative (e.g. prices/products.json) or bundle-shared under policy/ or formats/"
            },
            "depends_on": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^(policy/[a-z0-9_./-]+\\.json|formats/[a-z0-9_./-]+\\.json|[a-z0-9_./-]+\\.json)$"
              },
              "description": "List of dependent files (same path convention as file)"
            },
            "description": {
              "type": "string",
              "minLength": 1,
              "description": "Dependency description"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "edges": {
      "type": "object",
      "description": "Per-product edges: each key must be a **product `id`** from products.json (provider-native catalog key), not `porto_id`. Maps product \u2192 allowed zones and weight tiers.",
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "object",
          "required": [
            "zones",
            "weight_tiers"
          ],
          "properties": {
            "zones": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "pattern": "^[a-z0-9_]+$"
              },
              "description": "Available zones for this product (provider-specific ids, e.g. domestic, zone_1_eu, zone_2, world)"
            },
            "weight_tiers": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "pattern": "^W[0-9]+$"
              },
              "description": "Available weight tiers for this product"
            },
            "mark_profile_by_zone": {
              "type": "object",
              "minProperties": 1,
              "patternProperties": {
                "^[a-z0-9_]+$": {
                  "type": "string",
                  "pattern": "^[a-z0-9_]+$"
                }
              },
              "additionalProperties": false,
              "description": "Optional zone \u2192 marks.json profile id when footprint differs by destination lane. Keys must be a subset of zones. SDK falls back to products.mark_profile then marks.default_profile."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+$"
      },
      "description": "Attachable services for this provider. Each entry must match **services.json `id`** (provider-native key). Price paths and join keys come from **dependencies** and price schemas (`product_prices`, `service_prices`), not from graph config."
    }
  },
  "additionalProperties": false
}
