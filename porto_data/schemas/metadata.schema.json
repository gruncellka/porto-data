{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/gruncellka/porto-data/refs/heads/main/porto_data/schemas/metadata.schema.json",
  "title": "Porto-data bundle metadata",
  "description": "Generated checksum manifest for schemas and data files (see scripts/generate_metadata.py). The bundle section records mappings.json and providers.json (plus schemas) explicitly.",
  "type": "object",
  "required": [
    "$schema",
    "project",
    "generated_at",
    "policy",
    "formats",
    "registry",
    "providers",
    "checksums"
  ],
  "additionalProperties": false,
  "definitions": {
    "fileInfo": {
      "type": "object",
      "required": [
        "path",
        "checksum",
        "size"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "checksum": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "size": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "schemaInfo": {
      "type": "object",
      "required": [
        "path",
        "checksum",
        "size",
        "url"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "checksum": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "url": {
          "type": "string",
          "description": "Schema $id URL when present; empty string if unavailable."
        }
      }
    },
    "entityBundle": {
      "type": "object",
      "required": [
        "data",
        "schema"
      ],
      "additionalProperties": false,
      "properties": {
        "data": {
          "$ref": "#/definitions/fileInfo"
        },
        "schema": {
          "$ref": "#/definitions/schemaInfo"
        }
      }
    }
  },
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "project": {
      "type": "object",
      "required": [
        "name",
        "version",
        "description"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "generated_at": {
      "type": "string",
      "minLength": 1,
      "description": "ISO 8601 instant (UTC, Z suffix from generator)."
    },
    "policy": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/entityBundle"
      }
    },
    "formats": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/entityBundle"
      }
    },
    "registry": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/entityBundle"
      }
    },
    "providers": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "minProperties": 1,
        "additionalProperties": {
          "$ref": "#/definitions/entityBundle"
        }
      }
    },
    "bundle": {
      "type": "object",
      "description": "Root manifest files: mappings (layout) and providers registry, each with data + schema checksums.",
      "required": [
        "mappings",
        "providers_registry"
      ],
      "additionalProperties": false,
      "properties": {
        "mappings": {
          "$ref": "#/definitions/entityBundle"
        },
        "providers_registry": {
          "$ref": "#/definitions/entityBundle"
        }
      }
    },
    "checksums": {
      "type": "object",
      "required": [
        "algorithm",
        "note"
      ],
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "SHA-256"
        },
        "note": {
          "type": "string"
        }
      }
    }
  }
}
