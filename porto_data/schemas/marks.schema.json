{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/gruncellka/porto-data/refs/heads/main/porto_data/schemas/marks.schema.json",
  "title": "Provider mark profiles",
  "description": "Per-provider catalog of mark geometry and payload type. Profile size (width × height) is nominal footprint in mm. Resolution paths live in graph.json edges.marks.",
  "type": "object",
  "required": [
    "file_type",
    "default_profile",
    "profiles"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "description": "JSON Schema URI reference"
    },
    "file_type": {
      "type": "string",
      "const": "marks",
      "description": "File type identifier"
    },
    "unit": {
      "type": "object",
      "required": [
        "dimension"
      ],
      "properties": {
        "dimension": {
          "type": "string",
          "const": "mm",
          "description": "Intrinsic size and layout coordinates use millimetres"
        }
      },
      "additionalProperties": false
    },
    "default_profile": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Fallback profile id when graph.edges.marks has no entry for a zone"
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "mark_type",
          "label"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$",
            "description": "Stable profile id; referenced from graph.edges.marks"
          },
          "mark_type": {
            "type": "string",
            "enum": [
              "stamp",
              "label"
            ],
            "description": "Must match product.mark_type for products using this profile"
          },
          "label": {
            "type": "string",
            "minLength": 1,
            "description": "English short name for tooling"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "When to use this profile vs others"
          },
          "scope_notes": {
            "type": "string",
            "minLength": 1,
            "description": "Optional: domestic vs international, registered, channel notes"
          },
          "size": {
            "type": "object",
            "description": "Nominal width × height of the franking graphic in file unit.dimension (mm); optional until verified from API/spec",
            "required": [
              "width",
              "height"
            ],
            "properties": {
              "width": {
                "type": "integer",
                "minimum": 1
              },
              "height": {
                "type": "integer",
                "minimum": 1
              }
            },
            "additionalProperties": false
          },
          "mime_type": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "image/png",
                "application/pdf",
                "application/octet-stream"
              ]
            },
            "description": "IANA media types the provider API may return for this profile; order is not significant"
          }
        },
        "additionalProperties": false
      }
    },
    "calibrations": {
      "type": "array",
      "description": "Optional checkout asset dimensions (integration × voucher layout × dpi)",
      "items": {
        "type": "object",
        "required": [
          "integration",
          "voucher_layout",
          "mime_type",
          "dpi"
        ],
        "properties": {
          "integration": {
            "type": "string",
            "minLength": 1,
            "description": "graph.edges.wire integration key (same id namespace as integration.json adapter when present)"
          },
          "voucher_layout": {
            "type": "string",
            "minLength": 1,
            "description": "Integration-specific checkout layout token at purchase time (opaque catalog string; allowed values belong in operator docs)"
          },
          "mime_type": {
            "type": "string",
            "enum": [
              "image/png",
              "application/pdf"
            ]
          },
          "dpi": {
            "type": "integer",
            "minimum": 1,
            "description": "Checkout raster dpi used when measuring or requesting assets (e.g. 300)"
          },
          "by_mark_profile": {
            "type": "object",
            "description": "Per mark_profile measured asset dimensions (when layout varies by profile)",
            "additionalProperties": {
              "type": "object",
              "required": [
                "width_px",
                "height_px",
                "width_mm",
                "height_mm"
              ],
              "properties": {
                "width_px": {
                  "type": "integer",
                  "minimum": 1
                },
                "height_px": {
                  "type": "integer",
                  "minimum": 1
                },
                "width_mm": {
                  "type": "number",
                  "minimum": 0
                },
                "height_mm": {
                  "type": "number",
                  "minimum": 0
                }
              },
              "additionalProperties": false
            }
          },
          "label_canvas": {
            "type": "object",
            "description": "Single shared label canvas dimensions (when layout is uniform across profiles)",
            "required": [
              "width_px",
              "height_px",
              "width_mm",
              "height_mm"
            ],
            "properties": {
              "width_px": {
                "type": "integer",
                "minimum": 1
              },
              "height_px": {
                "type": "integer",
                "minimum": 1
              },
              "width_mm": {
                "type": "number",
                "minimum": 0
              },
              "height_mm": {
                "type": "number",
                "minimum": 0
              }
            },
            "additionalProperties": false
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
