{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/gruncellka/porto-data/refs/heads/main/porto_data/schemas/zones.schema.json",
  "title": "Zones Schema",
  "description": "Schema for shipping zones definitions",
  "type": "object",
  "required": [
    "file_type",
    "provider",
    "unit",
    "zones"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "description": "JSON Schema URI reference"
    },
    "file_type": {
      "type": "string",
      "const": "zones",
      "description": "File type identifier"
    },
    "provider": {
      "type": "string",
      "pattern": "^[a-z_]+$",
      "description": "Provider identifier (e.g. deutschepost, swisspost)"
    },
    "unit": {
      "type": "object",
      "required": [
        "country_code"
      ],
      "properties": {
        "country_code": {
          "type": "string",
          "const": "ISO 3166-1 alpha-2"
        }
      },
      "additionalProperties": false
    },
    "zones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "country_codes"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$",
            "description": "Zone ID"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Zone name"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "Zone description"
          },
          "country_codes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[A-Z]{2}$",
              "description": "ISO 3166-1 alpha-2 country code"
            },
            "description": "List of country codes in this zone"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
