{
  "$schema": "https://raw.githubusercontent.com/gruncellka/porto-data/refs/heads/main/porto_data/schemas/graph.schema.json",
  "file_type": "graph",
  "provider": "ukrposhta",
  "unit": {
    "weight": "g",
    "dimension": "mm",
    "price": "cents",
    "currency": "UAH"
  },
  "dependencies": {
    "products": {
      "file": "products.json",
      "depends_on": [
        "zones.json",
        "weights.json",
        "mails/envelopes.json",
        "services.json",
        "features.json",
        "marks.json"
      ],
      "description": "Products require zones, weight tiers, envelope formats, services, features, and mark profiles"
    },
    "services": {
      "file": "services.json",
      "depends_on": [
        "features.json"
      ],
      "description": "Services reference feature ids"
    },
    "product_prices": {
      "file": "prices/products.json",
      "depends_on": [
        "products.json",
        "zones.json",
        "weights.json"
      ],
      "description": "Base postage grid for Ukrposhta letter products"
    },
    "service_prices": {
      "file": "prices/services.json",
      "depends_on": [
        "products.json",
        "services.json",
        "zones.json",
        "weights.json"
      ],
      "description": "Service surcharge amounts"
    },
    "zones": {
      "file": "zones.json",
      "depends_on": [
        "policy/restrictions.json"
      ],
      "description": "Domestic/international zone definitions"
    },
    "weights": {
      "file": "weights.json",
      "depends_on": [],
      "description": "Weight brackets"
    },
    "envelopes": {
      "file": "mails/envelopes.json",
      "depends_on": [],
      "description": "Envelope catalog"
    },
    "marks": {
      "file": "marks.json",
      "depends_on": [],
      "description": "Label profiles for Ukrposhta"
    },
    "features": {
      "file": "features.json",
      "depends_on": [],
      "description": "Feature catalog"
    },
    "limits": {
      "file": "limits.json",
      "depends_on": [
        "policy/restrictions.json"
      ],
      "description": "Operational limits overlay"
    }
  },
  "edges": {
    "letter_standard": {
      "zones": [
        "domestic",
        "world"
      ],
      "weight_tiers": [
        "W0050",
        "W0250",
        "W1000",
        "W2000"
      ]
    },
    "ukrposhta_document": {
      "zones": [
        "domestic"
      ],
      "weight_tiers": [
        "W1000"
      ]
    }
  },
  "lookup_rules": {
    "price_lookup": "Base postage: prices/products.json (product_prices[]). Service surcharges: prices/services.json (service_prices[]).",
    "service_lookup": "Find service in services.json by id",
    "weight_resolution": "Resolve weight_tier id from weights.json where min <= weight <= max",
    "zone_validation": "Check if zone is in product's zones array"
  },
  "global_settings": {
    "price_lookup": {
      "product_prices": {
        "file": "prices/products.json",
        "array": "product_prices",
        "match": {
          "product_id": "from products.json native id",
          "zone": "from zones array",
          "weight_tier": "from weight_tiers array"
        },
        "description": "Domestic letters and document tariffs (UAH cents)."
      },
      "service_prices": {
        "file": "prices/services.json",
        "array": "service_prices",
        "match": {
          "service_id": "from services.json native id"
        },
        "description": "Optional service surcharges (UAH/ USD cents)."
      }
    },
    "available_services": [
      "return_receipt_paper",
      "return_receipt_electronic",
      "recommended_intl"
    ]
  }
}
