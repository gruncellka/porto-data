{
  "$schema": "https://raw.githubusercontent.com/gruncellka/porto-data/refs/heads/main/porto_data/schemas/graph.schema.json",
  "file_type": "graph",
  "provider": "deutschepost",
  "unit": {
    "weight": "g",
    "dimension": "mm",
    "price": "cents",
    "currency": "EUR"
  },
  "dependencies": {
    "products": {
      "file": "products.json",
      "depends_on": [
        "zones.json",
        "weights.json",
        "formats/envelopes.json",
        "services.json",
        "features.json",
        "marks.json"
      ],
      "description": "Products require zones, weight tiers, canonical envelope format ids, services, features, and mark profiles"
    },
    "services": {
      "file": "services.json",
      "depends_on": [
        "features.json"
      ],
      "description": "Services require features and price information"
    },
    "product_prices": {
      "file": "prices/products.json",
      "depends_on": [
        "products.json",
        "zones.json",
        "weights.json"
      ],
      "description": "Base postage grid (product_id \u00d7 zone \u00d7 weight_tier); file providers/<id>/prices/products.json (file_type product_prices)"
    },
    "service_prices": {
      "file": "prices/services.json",
      "depends_on": [
        "products.json",
        "services.json",
        "zones.json",
        "weights.json"
      ],
      "description": "Service surcharge amounts; file providers/<id>/prices/services.json (file_type service_prices)"
    },
    "zones": {
      "file": "zones.json",
      "depends_on": [
        "policy/restrictions.json"
      ],
      "description": "Zones may have restricted destinations"
    },
    "weights": {
      "file": "weights.json",
      "depends_on": [],
      "description": "Weight brackets (tier ids) are standalone definitions"
    },
    "envelopes": {
      "file": "formats/envelopes.json",
      "depends_on": [],
      "description": "Global envelope id catalog: physical front size (mm); international baseline (e.g. ISO 269); file formats/envelopes.json"
    },
    "envelope_layouts": {
      "file": "formats/layouts.json",
      "depends_on": [
        "formats/envelopes.json"
      ],
      "description": "Jurisdiction-keyed print/window layout (DE/CH/FR); file formats/layouts.json"
    },
    "jurisdictions": {
      "file": "policy/jurisdictions.json",
      "depends_on": [],
      "description": "UN/EU membership sets for restriction framework jurisdiction resolution"
    },
    "markets": {
      "file": "policy/markets.json",
      "depends_on": [],
      "description": "Country-level currency, VAT, and intl quote currencies for providers.json country"
    },
    "restrictions": {
      "file": "policy/restrictions.json",
      "depends_on": [
        "policy/jurisdictions.json",
        "zones.json",
        "products.json"
      ],
      "description": "Global destination restrictions (bundled as policy/restrictions.json); optional cross-reference to zones and products"
    },
    "limits": {
      "file": "limits.json",
      "depends_on": [
        "policy/restrictions.json"
      ],
      "description": "Provider operational limits extend global restrictions after load"
    },
    "features": {
      "file": "features.json",
      "depends_on": [],
      "description": "Features are standalone definitions referenced by services"
    },
    "marks": {
      "file": "marks.json",
      "depends_on": [],
      "description": "Provider mark/stamp/label physical defaults; referenced optionally from products.mark_profile"
    }
  },
  "edges": {
    "standardbrief": {
      "zones": [
        "domestic",
        "zone_1_eu",
        "zone_2_europe",
        "world"
      ],
      "weight_tiers": [
        "W0020"
      ],
      "mark_profile_by_zone": {
        "domestic": "domestic",
        "zone_1_eu": "international",
        "zone_2_europe": "international",
        "world": "international"
      }
    },
    "kompaktbrief": {
      "zones": [
        "domestic",
        "zone_1_eu",
        "zone_2_europe",
        "world"
      ],
      "weight_tiers": [
        "W0050"
      ],
      "mark_profile_by_zone": {
        "domestic": "domestic",
        "zone_1_eu": "international",
        "zone_2_europe": "international",
        "world": "international"
      }
    },
    "grossbrief": {
      "zones": [
        "domestic",
        "zone_1_eu",
        "zone_2_europe",
        "world"
      ],
      "weight_tiers": [
        "W0500"
      ],
      "mark_profile_by_zone": {
        "domestic": "domestic",
        "zone_1_eu": "international",
        "zone_2_europe": "international",
        "world": "international"
      }
    },
    "maxibrief": {
      "zones": [
        "domestic",
        "zone_1_eu",
        "zone_2_europe",
        "world"
      ],
      "weight_tiers": [
        "W1000"
      ],
      "mark_profile_by_zone": {
        "domestic": "domestic",
        "zone_1_eu": "international",
        "zone_2_europe": "international",
        "world": "international"
      }
    },
    "maxibrief_international_heavy": {
      "zones": [
        "zone_1_eu",
        "zone_2_europe",
        "world"
      ],
      "weight_tiers": [
        "W2000"
      ],
      "mark_profile_by_zone": {
        "zone_1_eu": "international",
        "zone_2_europe": "international",
        "world": "international"
      }
    }
  },
  "services": [
    "einschreiben",
    "einschreiben_einwurf",
    "einschreiben_rueckschein",
    "zusatzversicherung"
  ]
}
